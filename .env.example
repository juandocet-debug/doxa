# Configuraion de base de datos
# Para desarrollo local con SQLite usa "file:./prisma/dev.db"
# Para PostgreSQL/MySQL usa la URL de conexion correspondiente
DATABASE_URL=""

# Secretos de autenticacion (Requeridos en produccion y arranque)
# AUTH_SECRET debe ser una cadena aleatoria segura
AUTH_SECRET=""
SUPER_PASSWORD=""
GENERIC_PASSWORD=""
VERIFICADOR_PASSWORD=""

# Integracion con Tally Forms
TALLY_API_KEY=""
TALLY_API_URL="https://api.tally.so"
TALLY_MCP_URL="https://api.tally.so/mcp"

# Configuracion de Almacenamiento (S3/R2/Blob/Local)
# Valores permitidos para STORAGE_PROVIDER: "local", "s3"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_DIR="public/uploads"
STORAGE_BUCKET_NAME=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# Integracion con Google Drive (para copias de respaldo / envios de ZIPs)
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_DRIVE_FOLDER_ID=""
