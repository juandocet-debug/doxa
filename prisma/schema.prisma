generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Meta {
  id          String       @id @default(cuid())
  nombre      String
  descripcion String?
  estado      String       @default("activa")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  componentes Componente[]
  registros   Registro[]
}

model Componente {
  id          String     @id @default(cuid())
  metaId      String
  nombre      String
  descripcion String?
  estado      String     @default("activo")
  orden       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  meta        Meta       @relation(fields: [metaId], references: [id])
  acciones         Accion[]
  registros        Registro[]
  tallyFormulario  TallyFormulario?
  @@index([metaId])
}

model Accion {
  id                 String               @id @default(cuid())
  componenteId       String
  nombre             String
  descripcion        String?
  requiereInstancia  Boolean              @default(false)
  tipoInstancia      String?
  cantidadInstancias Int?
  estado             String               @default("activa")
  orden              Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  componente         Componente           @relation(fields: [componenteId], references: [id])
  instancias         InstanciaAccion[]
  evidenciasReq      EvidenciaRequerida[]
  registros          Registro[]
  @@index([componenteId])
}

model InstanciaAccion {
  id        String     @id @default(cuid())
  accionId  String
  nombre    String
  numero    Int?
  tipo      String?
  estado    String     @default("activa")
  orden     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  accion    Accion     @relation(fields: [accionId], references: [id])
  registros Registro[]
  @@index([accionId])
}

model EvidenciaRequerida {
  id                 String             @id @default(cuid())
  accionId           String
  nombre             String
  tipoArchivo        String             @default("foto")
  multiple           Boolean            @default(true)
  obligatorio        Boolean            @default(true)
  orden              Int                @default(0)
  estado             String             @default("activa")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accion             Accion             @relation(fields: [accionId], references: [id])
  evidenciasCargadas EvidenciaCargada[]
  @@index([accionId])
}

model Registro {
  id                String             @id @default(cuid())
  metaId            String
  componenteId      String
  accionId          String
  instanciaAccionId String?
  fechaActividad    DateTime
  responsable       String
  municipio         String
  localidad         String?
  lugar             String?
  observaciones     String?
  estado            String             @default("borrador")
  createdBy         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  meta              Meta               @relation(fields: [metaId], references: [id])
  componente        Componente         @relation(fields: [componenteId], references: [id])
  accion            Accion             @relation(fields: [accionId], references: [id])
  instancia         InstanciaAccion?   @relation(fields: [instanciaAccionId], references: [id])
  evidencias        EvidenciaCargada[]
  @@index([metaId])
  @@index([componenteId])
  @@index([accionId])
  @@index([instanciaAccionId])
  @@index([estado])
  @@index([createdBy])
}

model EvidenciaCargada {
  id                   String              @id @default(cuid())
  registroId           String
  evidenciaRequeridaId String
  estado               String              @default("pendiente")
  observacionRevision  String?
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  registro             Registro            @relation(fields: [registroId], references: [id], onDelete: Cascade)
  evidenciaRequerida   EvidenciaRequerida  @relation(fields: [evidenciaRequeridaId], references: [id])
  archivos             ArchivoEvidencia[]
  @@index([registroId])
  @@index([estado])
}

model TallyFormulario {
  id           String     @id @default(cuid())
  componenteId String     @unique
  tallyFormId  String     @unique
  tallyFormUrl String
  titulo       String
  createdAt    DateTime   @default(now())
  componente   Componente @relation(fields: [componenteId], references: [id])
  @@index([componenteId])
}

model ArchivoEvidencia {
  id                 String           @id @default(cuid())
  evidenciaCargadaId String
  nombreOriginal     String
  nombreAlmacenado   String
  urlArchivo         String
  tipoMime           String
  extension          String
  peso               Int
  uploadedBy         String
  createdAt          DateTime         @default(now())
  evidencia          EvidenciaCargada @relation(fields: [evidenciaCargadaId], references: [id], onDelete: Cascade)
  @@index([evidenciaCargadaId])
}

model AprobacionTally {
  id                String   @id @default(cuid())
  tallySubmissionId String   @unique
  formId            String
  estado            String   @default("pendiente")
  notas             String?
  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt
  @@index([formId])
  @@index([estado])
}

model EvidenciaTallyReemplazo {
  id                  String   @id @default(cuid())
  tallySubmissionId   String
  formId              String
  questionId          String?
  tallyFileUrl        String   @db.Text
  tallyFileName       String?
  replacementUrl      String   @db.Text
  replacementPublicId String?
  replacementName     String?
  replacementMime     String?
  replacementSize     Int?
  storageProvider     String   @default("cloudinary")
  motivo              String
  replacedBy          String?
  replacedAt          DateTime @default(now())
  active              Boolean  @default(true)

  @@index([tallySubmissionId])
  @@index([formId])
  @@index([tallyFileUrl])
}

model TallySubmissionSnapshot {
  id                String   @id @default(cuid())
  tallySubmissionId String   @unique
  formId            String
  componenteId      String?
  componenteNombre  String?
  grupo             String?
  clase             String?
  fechaEnvio        DateTime?
  rawJson           Json?
  syncedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  archivos          TallyArchivoSnapshot[]

  @@index([formId])
  @@index([componenteId])
  @@index([grupo])
  @@index([clase])
  @@index([fechaEnvio])
}

model TallyArchivoSnapshot {
  id                String   @id @default(cuid())
  snapshotId        String
  tallySubmissionId String
  formId            String
  questionId        String?
  questionLabel     String?
  tallyFileId       String?
  tallyFileName     String?
  tallyFileUrl      String   @unique @db.Text
  tallyMime         String?
  tallySize         Int?

  cloudinaryUrl      String?  @db.Text
  cloudinaryPublicId String?
  cloudinaryMime     String?
  cloudinarySize     Int?

  syncStatus        String   @default("pending") // pending | synced | failed
  syncError         String?  @db.Text
  syncedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  snapshot          TallySubmissionSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([tallySubmissionId])
  @@index([formId])
  @@index([questionId])
  @@index([syncStatus])
}

model TallyDeletedSubmission {
  id                String   @id @default(cuid())
  tallySubmissionId String   @unique
  createdAt         DateTime @default(now())
}

model DoxaUsuario {
  id             String   @id @default(cuid())
  externalUserId String   @unique
  nombre         String
  email          String?
  documento      String?
  rolBase        String?
  fotoUrl        String?
  activo         Boolean  @default(true)
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  permisos       DoxaPermisoComponente[]
  auditorias     DoxaAuditoria[]
}

model DoxaPermisoComponente {
  id                    String  @id @default(cuid())
  usuarioId             String
  componenteId           String

  puedeVer               Boolean @default(false)
  puedeAprobar           Boolean @default(false)
  puedeDevolver          Boolean @default(false)
  puedeReemplazar        Boolean @default(false)
  puedeSincronizarBackup Boolean @default(false)
  puedeExportar          Boolean @default(false)

  usuario                DoxaUsuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, componenteId])
  @@index([componenteId])
}

model DoxaAuditoria {
  id                String   @id @default(cuid())
  usuarioId         String?
  accion            String
  componenteId      String?
  formId            String?
  tallySubmissionId String?
  clase             String?
  grupo             String?
  estadoAnterior    String?
  estadoNuevo       String?
  detalle           String?
  createdAt         DateTime @default(now())

  usuario           DoxaUsuario? @relation(fields: [usuarioId], references: [id])
}

